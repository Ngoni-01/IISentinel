# IISentinel™ — Environment Configuration Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── CORE ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── DATABASE (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ── SMS GATEWAY ───────────────────────────────────────────────────────────────
# Choose ONE gateway: africastalking | twilio | vonage | generic
SMS_GATEWAY=africastalking

# Africa's Talking (Southern/Eastern Africa)
AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key
ALERT_PHONE=+263771234567        # Primary alert recipient (with country code)

# Twilio (global)
# SMS_GATEWAY=twilio
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your-auth-token
# TWILIO_FROM=+12025551234

# Vonage / Nexmo (global)
# SMS_GATEWAY=vonage
# VONAGE_KEY=your-key
# VONAGE_SECRET=your-secret
# VONAGE_FROM=IISentinel

# Generic HTTP gateway (any provider with a REST API)
# SMS_GATEWAY=generic
# SMS_GATEWAY_URL=https://api.yoursms.com/send
# SMS_API_KEY=your-api-key

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password        # Use an App Password, not your main password
SMTP_FROM=IISentinel™ <alerts@yourdomain.com>
ALERT_EMAIL=ops-team@yourdomain.com

# ── WHATSAPP BUSINESS API ─────────────────────────────────────────────────────
WA_TOKEN=your-whatsapp-business-token
WA_PHONE_ID=your-whatsapp-phone-number-id
WA_TO=+263771234567               # Recipient WhatsApp number (with country code)

# ── CBS SAFETY ────────────────────────────────────────────────────────────────
# Phone that ALWAYS receives CBS blast hold SMS regardless of other settings
CBS_ALERT_PHONE=+263771234567

# ── DEPLOYMENT ────────────────────────────────────────────────────────────────
# Set to False in production
FLASK_DEBUG=False
# Port (default 5000)
PORT=5000
